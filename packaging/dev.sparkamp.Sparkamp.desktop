[Desktop Entry]
Name=Sparkamp
Comment=Winamp-style audio player for Linux
Exec=sparkamp %F
Icon=dev.sparkamp.Sparkamp
Terminal=false
Type=Application
Categories=AudioVideo;Audio;Player;
MimeType=audio/mpeg;audio/ogg;audio/flac;audio/x-flac;audio/wav;audio/x-wav;audio/aac;audio/mp4;audio/x-m4a;application/ogg;
Keywords=music;audio;player;winamp;mp3;
StartupNotify=true

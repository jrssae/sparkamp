# Rust build artifacts (~1.7 GB — never commit these)
/target

# macOS system files
.DS_Store

# Xcode user-specific state (not project configuration)
xcuserdata/
*.xcworkspace/xcuserdata/

# Compiled static library produced by the Cargo build phase — regenerated on
# every Xcode build; committing it would bloat the repo with binary churn.
frontends/SparkampMac/libsparkamp_macos.a

# Vendored dependencies (cargo vendor)
/vendor/

# Flatpak build artifacts
/flatpak-cargo-generator.py
/repo/
/build-dir/
/.flatpak-builder/
/Sparkamp.flatpak

# Development / scratch files
dev.txt

# Test media files — copyrighted, must never reach GitHub
/Testing/

# Built distribution artifacts (DMGs, installers) — too large for git
/dist/

# Per-developer macOS xcodebuild export config (generated/edited locally)
packaging/macos/export-options.plist

# Other large binaries not needed in the repo
*.wsz
*.mp3
*.jpg
*.png
!square logo.png
!frontends/SparkampMac/Assets.xcassets/**/*.png

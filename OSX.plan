## Phase 3: SwiftUI Windows

### Duration: 7 days

### Window Breakdown

| Window | SwiftUI | Complexity | Lines |
|--------|---------|-----------|-------|
| Main Player | ZStack, HStack, VStack | High | ~800 |
| Playlist | List + @State | Medium | ~600 |
| Media Library | Table (macOS 13+) | High | ~900 |
| EQ | HStack of Sliders | Medium | ~400 |
| Settings | TabView + Form | Medium | ~500 |
| ID3 Editor | Form + TextField | Low | ~300 |
| Jump/Search | SearchField + filtered List | Low | ~200 |
| **Total** | | | **~3700** |

### Main Player View Pattern

```swift
// Sparkamp/Views/MainPlayerView.swift

import SwiftUI

struct MainPlayerView: View {
    @ObservedObject var bridge = SparkampBridge.shared
    @State private var position: Double = 0
    @State private var isPlaying = false
    
    var body: some View {
        VStack(spacing: 0) {
            // Visualizer
            Canvas { ctx, size in
                // Draw bars/oscilloscope from bridge.vizData
            }
            .frame(height: 100)
            
            // Marquee
            MarqueeText(text: bridge.currentTrackTitle)
                .frame(height: 30)
            
            // Seek bar
            Slider(value: $position, in: 0...bridge.duration) { editing in
                if !editing {
                    bridge.seek(position)
                }
            }
            
            // Transport controls
            HStack {
                Button(action: { bridge.previous() }) { Image(systemName: "backward.fill") }
                Button(action: { bridge.togglePlay() }) {
                    Image(systemName: isPlaying ? "pause.fill" : "play.fill")
                }
                Button(action: { bridge.stop() }) { Image(systemName: "stop.fill") }
                Button(action: { bridge.next() }) { Image(systemName: "forward.fill") }
            }
            
            // Volume
            HStack {
                Image(systemName: "speaker.fill")
                Slider(value: $bridge.volume, in: 0...1)
            }
        }
        .frame(width: 520, height: 200)
        .onAppear { startTick() }
    }
    
    private func startTick() {
        Timer.publish(every: 0.1, on: .main, in: .common)
            .autoconnect()
            .sink { _ in
                position = bridge.position
                isPlaying = bridge.isPlaying
            }
    }
}
```

### Media Library View (macOS 13+ Table)

```swift
// Sparkamp/Views/MediaLibraryView.swift

import SwiftUI

struct MediaLibraryView: View {
    @ObservedObject var bridge = SparkampBridge.shared
    @State private var searchText = ""
    @State private var sortOrder = [KeyPathComparator(\MLTrack.title)]
    
    var body: some View {
        NavigationSplitView {
            List {
                Button("Files") { }
                Button("Playlists") { }
            }
            .frame(width: 130)
        } detail: {
            VStack {
                TextField("Search...", text: $searchText)
                    .textFieldStyle(.roundedBorder)
                    .padding()
                
                Table(filteredTracks, sortOrder: $sortOrder) {
                    TableColumn("#", value: \.trackNum) { track in
                        Text("\(track.trackNum)")
                    }
                    TableColumn("Title", value: \.title)
                    TableColumn("Artist", value: \.artist)
                    TableColumn("Album", value: \.album)
                    TableColumn("Duration", value: \.duration) { track in
                        Text(formatDuration(track.duration))
                    }
                }
            }
        }
    }
    
    var filteredTracks: [MLTrack] {
        bridge.mlTracks.filter {
            searchText.isEmpty ||
            $0.title.localizedCaseInsensitiveContains(searchText) ||
            $0.artist.localizedCaseInsensitiveContains(searchText)
        }
    }
    
    func formatDuration(_ secs: Double) -> String {
        let m = Int(secs) / 60
        let s = Int(secs) % 60
        return "\(m):\(String(format: "%02d", s))"
    }
}
```

### Window Management

Use multiple `WindowGroup` or `NSWindow` with `WindowStyle`:

```swift
// Sparkamp/App.swift

import SwiftUI

@main
struct SparkampApp: App {
    var body: some Scene {
        MainWindow()
        WindowGroup("Playlist") { PlaylistView() }
        WindowGroup("Media Library") { MediaLibraryView() }
        WindowGroup("Equalizer") { EQView() }
        WindowGroup("Settings") { SettingsView() }
    }
}
```


### Package.swift

```swift
// swift-tools-version: 5.9
import PackageDescription

let package = Package(
    name: "Sparkamp",
    platforms: [.macOS(.v13)],
    products: [
        .executable(
            name: "sparkamp",
            targets: ["Sparkamp"]
        )
    ],
    dependencies: [],
    targets: [
        .executableTarget(
            "Sparkamp",
            path: "Sparkamp",
            sources: ["."]
        )
    ]
)
```

### Swift FFI Bridge

```swift
// Sparkamp/Bridge/SparkampBridge.swift

import Foundation
import Combine

final class SparkampBridge: ObservableObject {
    static let shared = SparkampBridge()
    
    private var lib: UnsafeMutableRawPointer?
    private var timer: Timer?
    
    // ── FFI Function Pointers ─────────────────────────────────────────────
    private var sparkInit: (@convention(c) () -> Void)?
    private var sparkPlay: (@convention(c) () -> Int32)?
    // ... etc
    
    private init() {
        loadLibrary()
    }
    
    private func loadLibrary() {
        // Try Homebrew prefix first, then bundle
        let prefixes = [
            "/opt/homebrew/lib/",
            "/usr/local/lib/",
            Bundle.main.bundlePath + "/Contents/Frameworks/"
        ]
        
        for prefix in prefixes {
            let path = prefix + "libsparkamp.dylib"
            if FileManager.default.fileExists(atPath: path) {
                lib = dlopen(path, RTLD_NOW)
                break
            }
        }
        
        guard let lib = lib else {
            // Show error: GStreamer not installed
            return
        }
        
        // Load symbols
        sparkInit = dlsym(lib, "spark_init")
        sparkPlay = dlsym(lib, "spark_play")
        // ... etc
    }
    
    // ── Swift API ─────────────────────────────────────────────────────────
    
    func play() {
        sparkPlay?()
    }
    
    // ... etc
}
```

